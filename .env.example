# 环境
ENVIRONMENT=development
DEBUG=True

# 数据库
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=formula_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# 机器学习
ML_MODEL_NAME=google/mt5-base
ML_DEVICE=cuda
ML_MAX_LENGTH=512
ML_BATCH_SIZE=32
ML_LEARNING_RATE=5e-5
ML_EPOCHS=3
ML_MODEL_CACHE=./models

# 日志
LOG_LEVEL=INFO

# 缓存
CACHE_TTL=3600
